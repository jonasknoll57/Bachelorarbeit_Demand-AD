      "source": [
        "# ── Fix 1: Kein StandardScaler auf bereits normierten Features ────────────\n",
        "# POI-Anteile, Landnutzungs-Anteile, Stunden-/Wochen-Profile sind bereits [0,1]-normiert\n",
        "# → StandardScaler würde diese Normierung zerstören und negative Werte erzeugen\n",
        "# → Nur kontext-Features (lat, lon, elevation, population) skalieren\n",
        "\n",
        "feature_matrix = pd.read_parquet(FEATURE_MATRIX_PATH)\n",
        "cities = feature_matrix.index.tolist()\n",
        "\n",
        "# Spalten nach Block identifizieren\n",
        "poi_cols      = [c for c in feature_matrix.columns if c.startswith('poi_')]\n",
        "lu_cols       = [c for c in feature_matrix.columns if c.startswith('lu_')]\n",
        "hourly_cols   = [c for c in feature_matrix.columns if c.startswith('h_')]\n",
        "weekly_cols   = [c for c in feature_matrix.columns if c.startswith('w_')]\n",
        "commuter_cols = [c for c in feature_matrix.columns if c.startswith('commuter')]\n",
        "context_num   = ['latitude', 'longitude', 'population']\n",
        "state_cols    = [c for c in feature_matrix.columns if c.startswith('state_')]\n",
        "\n",
        "print('Feature-Block Dimensionen:')\n",
        "for name, cols in [('POI', poi_cols), ('Landuse', lu_cols), ('Hourly', hourly_cols),\n",
        "                    ('Weekly', weekly_cols), ('Commuter', commuter_cols),\n",
        "                    ('Context num', context_num), ('State dummies', state_cols)]:\n",
        "    print(f'  {name:<15}: {len(cols)} Features')\n",
        "\n",
        "# ── Fix 2: Block-gewichtete Feature-Matrix ─────────────────────────────────\n",
        "# Problem: Hourly (48) + Weekly (14) dominieren gegenüber POI (10-20) und Landuse (10-15)\n",
        "# Lösung: Jeden Block auf einheitliche \"Gewichtungs-Einheit\" bringen,\n",
        "#         dann explizit gewichten nach inhaltlicher Relevanz für CCTL\n",
        "\n",
        "# Kontextuelle numerischen Features separat skalieren (nicht die normierten Profile!)\n",
        "from sklearn.preprocessing import StandardScaler, MinMaxScaler\n",
        "import numpy as np\n",
        "\n",
        "ctx_scaler = MinMaxScaler()  # MinMax statt Standard → bleibt in [0,1]\n",
        "ctx_scaled = ctx_scaler.fit_transform(feature_matrix[context_num].fillna(0))\n",
        "ctx_df = pd.DataFrame(ctx_scaled, index=feature_matrix.index, columns=context_num)\n",
        "\n",
        "# Block-Matrizen als Einheitsvektoren (L2-Norm pro Stadt)\n",
        "# → Jeder Block trägt gleich viel zur Similarity bei, unabhängig von Spaltenanzahl\n",
        "def block_to_unit(df_block):\n",
        "    arr = df_block.fillna(0).values.astype(float)\n",
        "    norms = np.linalg.norm(arr, axis=1, keepdims=True)\n",
        "    norms[norms == 0] = 1  # Division by zero vermeiden\n",
        "    return pd.DataFrame(arr / norms, index=df_block.index, columns=df_block.columns)\n",
        "\n",
        "# ── Gewichtung der Blöcke ──────────────────────────────────────────────────\n",
        "# Begründung aus CCTL-Literatur:\n",
        "#   - Nachfragemuster (hourly/weekly): wichtigster Transfer-Indikator → höchstes Gewicht\n",
        "#   - POI + Landuse: strukturelle Ähnlichkeit → mittleres Gewicht\n",
        "#   - Kontext: Hilfsgröße → niedriges Gewicht\n",
        "WEIGHTS = {\n",
        "    'demand':  0.50,   # hourly + weekly + commuter zusammen\n",
        "    'spatial': 0.35,   # POI + Landuse\n",
        "    'context': 0.15,   # Koordinaten, Einwohner, Bundesland\n",
        "}\n",
        "\n",
        "demand_block  = block_to_unit(feature_matrix[hourly_cols + weekly_cols + commuter_cols])\n",
        "spatial_block = block_to_unit(feature_matrix[poi_cols + lu_cols])\n",
        "context_block = block_to_unit(pd.concat([ctx_df, feature_matrix[state_cols]], axis=1))\n",
        "\n",
        "city_features_weighted = pd.concat([\n",
        "    demand_block  * WEIGHTS['demand'],\n",
        "    spatial_block * WEIGHTS['spatial'],\n",
        "    context_block * WEIGHTS['context'],\n",
        "], axis=1)\n",
        "\n",
        "print(f'\\nGewichtete Feature-Matrix: {city_features_weighted.shape}')\n",
        "print(f'Gewichte: Demand={WEIGHTS[\"demand\"]}, Spatial={WEIGHTS[\"spatial\"]}, Context={WEIGHTS[\"context\"]}')\n",
        "\n",
        "# X für Similarity: keine weitere Skalierung nötig (bereits normiert + gewichtet)\n",
        "X = city_features_weighted.fillna(0).values"
      ],
