        "  # ── Gewichte der Kriterien ─────────────────────────────────────────────────\n",
        "WEIGHTS = {\n",
        "    'data_volume':   0.20,   # Datenvolumen (Zeilen real)\n",
        "    'n_stations':    0.15,   # Stationsanzahl\n",
        "    'time_coverage': 0.15,   # Zeitliche Abdeckung (Monate)\n",
        "    'avg_epd':       0.15,   # Ø Nachfrage / Station / Tag\n",
        "    'coverage_pct':  0.10,   # Datenqualität (Coverage %)\n",
        "    'data_role':     0.25,   # Gibt es genug Daten für Source ODER ist es geeignet als Target?\n",
        "}\n",
        "assert abs(sum(WEIGHTS.values()) - 1.0) < 1e-9, 'Gewichte müssen sich zu 1 summieren'\n",
        "\n",
        "def score_1_to_5(series, higher_is_better=True):\n",
        "    \"\"\"Normiert eine numerische Serie auf 1–5 Sterne.\"\"\"\n",
        "    mn, mx = series.min(), series.max()\n",
        "    if mx == mn: return pd.Series([3.0] * len(series), index=series.index)\n",
        "    normalized = (series - mn) / (mx - mn)   # 0..1\n",
        "    if not higher_is_better:\n",
        "        normalized = 1 - normalized\n",
        "    return (normalized * 4 + 1).round(2)     # 1..5\n",
        "\n",
        "# Rohdaten pro Stadt\n",
        "dm = pd.DataFrame(index=metrics.index)\n",
        "dm['data_volume_raw']   = metrics.get('active_days', pd.Series(dtype=float)) * metrics.get('n_real_stations', pd.Series(dtype=float))  # Proxy\n",
        "dm['n_stations_raw']    = metrics['n_real_stations']\n",
        "dm['time_months_raw']   = metrics['total_months']\n",
        "dm['avg_epd_raw']       = metrics['avg_epd']\n",
        "dm['coverage_pct_raw']  = metrics['coverage_pct']\n",
        "\n",
        "# Scores 1–5\n",
        "dm['s_volume']    = score_1_to_5(dm['data_volume_raw'])\n",
        "dm['s_stations']  = score_1_to_5(dm['n_stations_raw'])\n",
        "dm['s_time']      = score_1_to_5(dm['time_months_raw'])\n",
        "dm['s_epd']       = score_1_to_5(dm['avg_epd_raw'])\n",
        "dm['s_coverage']  = score_1_to_5(dm['coverage_pct_raw'])\n",
        "\n",
        "# Source-Score (höher = besser als Source)\n",
        "dm['source_score'] = (\n",
        "    dm['s_volume']   * WEIGHTS['data_volume']   +\n",
        "    dm['s_stations'] * WEIGHTS['n_stations']    +\n",
        "    dm['s_time']     * WEIGHTS['time_coverage'] +\n",
        "    dm['s_epd']      * WEIGHTS['avg_epd']       +\n",
        "    dm['s_coverage'] * WEIGHTS['coverage_pct']\n",
        ") / (1 - WEIGHTS['data_role'])   # normieren ohne data_role\n",
        "\n",
        "# Target-Score (niedrig im Source-Score = guter Target-Kandidat, datenarm)\n",
        "dm['target_score'] = 6 - dm['source_score']   # invertiert\n",
        "\n",
        "dm['recommendation'] = metrics['recommendation']\n",
        "\n",
        "display(dm[['n_stations_raw','time_months_raw','avg_epd_raw','coverage_pct_raw',\n",
        "            'source_score','target_score','recommendation']]\n",
        "        .sort_values('source_score', ascending=False)\n",
        "        .round(2))"
