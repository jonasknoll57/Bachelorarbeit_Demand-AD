        "for tgt in target_cities:\n",
        "    sub = df_pairs[df_pairs['target'] == tgt]\n",
        "    ax.scatter(\n",
        "        sub['similarity'], [tgt] * len(sub),\n",
        "        color='#bbbbbb', s=40, zorder=2, alpha=0.7\n",
        "    )\n",
        "    # Verbindungslinie Min–Max\n",
        "    ax.hlines(tgt, sub['similarity'].min(), sub['similarity'].max(),\n",
        "              color='#cccccc', linewidth=1.0, zorder=1)\n",
        "\n",
        "# Bester Source pro Target als farbiger Punkt mit Label\n",
        "for _, row in best_per_target.iterrows():\n",
